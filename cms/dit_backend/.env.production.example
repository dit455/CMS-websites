# ─────────────────────────────────────────────────────────────────────────────
#  Django Production Environment Variables
#
#  1. Copy this file to  .env  (same folder as manage.py)
#  2. Fill in all values
#  3. NEVER commit the real .env to git
# ─────────────────────────────────────────────────────────────────────────────

# Generate a new secret key:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-this-with-a-long-random-secret-key

DEBUG=False

# Comma-separated list of domains Django will accept requests from
ALLOWED_HOSTS=api.dit.gov.in,admin.dit.gov.in,10.65.51.44

# PostgreSQL (recommended for production — much faster than SQLite)
DB_NAME=dit_cms
DB_USER=dit_user
DB_PASSWORD=your-strong-db-password
DB_HOST=localhost
DB_PORT=5432
