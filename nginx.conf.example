# ─────────────────────────────────────────────────────────────────────────────
#  NGINX PRODUCTION CONFIG  —  DIT Portal Multisite
#
#  File layout on the server:
#    /var/www/dit-portal/
#      dist/
#        site2/        ← built by build-all.ps1, uploaded here
#        health/
#        tourism/
#        ...
#      cms/dit_backend/
#        staticfiles/  ← generated by: python manage.py collectstatic
#        media/        ← user-uploaded files
#
#  How to use:
#    1. Copy this file to  /etc/nginx/sites-available/dit-portal
#    2. For each new site, copy the "server" block and change:
#         - server_name
#         - root path (dist/<key>)
#    3. Run: sudo nginx -t && sudo systemctl reload nginx
# ─────────────────────────────────────────────────────────────────────────────

# ── Django backend (Gunicorn) ─────────────────────────────────────────────────
upstream django_backend {
    server 127.0.0.1:8000;
}

# ── Site 2  (example: site2.dit.gov.in) ──────────────────────────────────────
server {
    listen 80;
    server_name site2.dit.gov.in;          # ← change to your domain

    root /var/www/dit-portal/dist/site2;   # ← built static files

    # Serve React app — all unknown routes go to index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy /api/ calls to Django
    location /api/ {
        proxy_pass         http://django_backend;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Serve uploaded media files directly
    location /media/ {
        alias /var/www/dit-portal/cms/dit_backend/media/;
    }

    # Serve Django admin static files
    location /static/ {
        alias /var/www/dit-portal/cms/dit_backend/staticfiles/;
    }
}

# ── Health Department  (health.dit.gov.in) ────────────────────────────────────
server {
    listen 80;
    server_name health.dit.gov.in;

    root /var/www/dit-portal/dist/health;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass         http://django_backend;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    location /media/ {
        alias /var/www/dit-portal/cms/dit_backend/media/;
    }

    location /static/ {
        alias /var/www/dit-portal/cms/dit_backend/staticfiles/;
    }
}

# ── Django Admin  (admin.dit.gov.in) ─────────────────────────────────────────
# Optional: dedicated domain just for the admin panel
server {
    listen 80;
    server_name admin.dit.gov.in;

    location / {
        proxy_pass         http://django_backend;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    location /media/ {
        alias /var/www/dit-portal/cms/dit_backend/media/;
    }

    location /static/ {
        alias /var/www/dit-portal/cms/dit_backend/staticfiles/;
    }
}

# NOTE: For HTTPS (SSL), add these inside each server block:
#   listen 443 ssl;
#   ssl_certificate     /etc/letsencrypt/live/yourdomain/fullchain.pem;
#   ssl_certificate_key /etc/letsencrypt/live/yourdomain/privkey.pem;
# Then redirect HTTP → HTTPS with a separate server block listening on 80.
