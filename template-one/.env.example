# ── Backend location ──────────────────────────────────────────────
# Points this React build at your running Django CMS backend.
VITE_API_BASE_URL=http://localhost:8000/api

# Where the Vite dev server proxy forwards /api and /media requests.
# Change this if Django runs on a different machine/IP — no code edits needed.
VITE_DJANGO_URL=http://localhost:8000

# ── Which website is this build? (multi-site) ─────────────────────
# The backend filters ALL content by this key, so the same template
# can power many sites. Create the matching Site in Django admin first
# (its "key" must equal this value). Leave blank to use the default site.
#   Examples: dit, deptb, health, tourism
VITE_SITE_KEY=dit

# Enables the in-browser CMS dashboard at #cms (optional)
VITE_ENABLE_CMS=true
